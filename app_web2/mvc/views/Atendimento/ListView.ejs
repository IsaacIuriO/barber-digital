<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>SGP - Lista de Atendimentos</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin">

    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            font-family: "Rubik", sans-serif;
            background-color: #F9DC5C;
        }

        .main-card{
            background-color: #F7F3E3;
            border: none;
            border-radius: 12px;
        }

        h1{
            color: #6F1A07;
            font-weight: 700;
        }

        .btn-primary{
            background-color: #6F1A07;
            border: none;
        }

        table{
            vertical-align: middle !important;
        }

    </style>

</head>

<body>

    <div class="container py-5">

        <div class="card main-card p-4 shadow">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h1>Agenda de Atendimentos</h1>

                    <p class="text-muted mb-0">
                        Lista completa dos atendimentos cadastrados.
                    </p>

                </div>

                <a href="/atendimento/create" class="btn btn-primary">
                    Novo Atendimento
                </a>

            </div>

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>
                            <th>Cliente</th>
                            <th>Contato</th>
                            <th>Data</th>
                            <th>Nascimento</th>
                            <th>Serviço</th>
                            <th>Profissional</th>
                            <th>Ações</th>
                        </tr>

                    </thead>

                    <tbody>

                        <% for(atendimento of atendimentos) { %>

                        <tr>

                            <td><%= atendimento.nomeCliente %></td>

                            <td><%= atendimento.telefone %></td>

                            <td>
                                <%= atendimento.dataAtendimento %>
                                -
                                <%= atendimento.horarioAtendimento %>
                            </td>

                            <td><%= atendimento.dataNascimento %></td>

                            <td><%= atendimento.tipoServico %></td>

                            <td><%= atendimento.profissional %></td>

                            <td class="d-flex gap-2">

                                <a
                                    href="/atendimento/edit/<%= atendimento.id %>"
                                    class="btn btn-warning btn-sm"
                                >
                                    Editar
                                </a>

                                <button
                                    onclick="confirmarExclusao('<%= atendimento.id %>')"
                                    class="btn btn-danger btn-sm"
                                >
                                    Excluir
                                </button>

                            </td>

                        </tr>

                        <% } %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <script>

        let atendimentoIdParaApagar = null;

        function confirmarExclusao(id){

            atendimentoIdParaApagar = id;

            const confirmar = confirm("Deseja realmente excluir este atendimento?");

            if(confirmar){
                deletar();
            }

        }

        async function deletar(){

            try{

                const response = await fetch("/atendimento/delete/" + atendimentoIdParaApagar, {
                    method: 'DELETE'
                });

                if(response.ok){
                    location.reload();
                }

            }
            catch(err){
                console.error(err);
            }

        }

    </script>

</body>

</html>
