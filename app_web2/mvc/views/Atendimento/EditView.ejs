<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Atendimento</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Rubik", sans-serif;
            background-color: #F9DC5C;
        }

        #card {
            background-color: #F7F3E3;
            width: 550px; /* Aumentado para acomodar os novos campos lateralmente */
            border: none;
            border-radius: 12px;
        }

        h1 {
            color: #6F1A07;
            font-size: 1.8rem;
        }

        label {
            color: #2B2118;
            font-weight: 500;
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

    <div class="container py-5 d-flex justify-content-center align-items-center">

        <div class="card p-4 shadow" id="card">

            <div class="mb-3" id="mensagem"></div>

            <h1 class="text-center mb-4">Editar Atendimento</h1>

            <input value="<%= atendimento.id %>" type="hidden" id="atendimentoId">

            <div class="mb-3">
                <label class="form-label" for="nomeCliente">Nome do Cliente</label>
                <input class="form-control" value="<%= atendimento.nomeCliente %>" id="nomeCliente" type="text">
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="telefone">Telefone</label>
                    <input class="form-control" value="<%= atendimento.telefone %>" id="telefone" type="tel">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="dataNascimento">Data de Nascimento</label>
                    <input class="form-control" value="<%= atendimento.dataNascimento %>" id="dataNascimento" type="date">
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="dataAtendimento">Data do Atendimento</label>
                    <input class="form-control" value="<%= atendimento.dataAtendimento %>" id="dataAtendimento" type="date">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label" for="horarioAtendimento">Horário</label>
                    <input class="form-control" value="<%= atendimento.horarioAtendimento %>" id="horarioAtendimento" type="time">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label" for="tipoServico">Tipo de Serviço</label>
                <input class="form-control" value="<%= atendimento.tipoServico %>" id="tipoServico" type="text">
            </div>

            <div class="mb-4">
                <label class="form-label" for="profissional">Profissional</label>
                <select required name="profissional" id="profissional">
                    <% for(usuario of usuarios){ %>
                        <option value="<%= usuario.id %> " <% atendimento.profissional == usuario.nome ? "selected" : "" %> selected><%= usuario.nome %></option>
                    <% } %>
                </select>
            </div>

            <div class="mb-3">
                <button class="btn btn-primary w-100" id="btnAtualizar" style="background-color: #6F1A07; border: none;">
                    Salvar Alterações
                </button>
            </div>
            
            <div class="text-center">
                <a href="/atendimento/list" class="text-decoration-none" style="color: #2B2118; font-size: 0.9rem;">Voltar para a lista</a>
            </div>

        </div>

    </div>

    <script>
        const btnAtualizar = document.getElementById("btnAtualizar");

        btnAtualizar.addEventListener("click", atualizarAtendimento);

        async function atualizarAtendimento(e) {
            e.preventDefault();

            const payload = {
                id: document.getElementById("atendimentoId").value,
                nomeCliente: document.getElementById("nomeCliente").value,
                telefone: document.getElementById("telefone").value,
                dataNascimento: document.getElementById("dataNascimento").value,
                dataAtendimento: document.getElementById("dataAtendimento").value,
                horarioAtendimento: document.getElementById("horarioAtendimento").value,
                tipoServico: document.getElementById("tipoServico").value,
                profissional: document.getElementById("profissional").value
            };

            const url = "/atendimento/edit";
            const mensagem = document.getElementById("mensagem");

            try {
                const response = await fetch(url, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (response.ok) {
                    mensagem.innerHTML = `
                        <div class="alert alert-success">
                            Atendimento atualizado com sucesso!
                        </div>
                    `;
                    
                } else {
                    mensagem.innerHTML = `
                        <div class="alert alert-danger">
                            Erro ao atualizar atendimento!
                        </div>
                    `;
                }
            } catch (error) {
                console.error("Erro:", error);
                mensagem.innerHTML = `<div class="alert alert-danger">Erro de conexão com o servidor.</div>`;
            }
        }
    </script>

</body>
</html>