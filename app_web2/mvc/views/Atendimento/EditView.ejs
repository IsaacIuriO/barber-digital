<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SGP - Editar Atendimento</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            font-family: "Rubik", sans-serif;
            background-color: #F9DC5C;
        }

        .main-card{
            background-color: #F7F3E3;
            border: none;
            border-radius: 12px;
        }

        h1{
            color: #6F1A07;
            font-weight: 700;
        }

        label{
            color: #2B2118;
            font-weight: 500;
        }

        .btn-primary{
            background-color: #6F1A07;
            border: none;
        }

    </style>

</head>

<body>

    <div class="container py-5">

        <div class="card main-card p-4 shadow">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>

                    <h1>Editar Atendimento</h1>

                    <p class="text-muted mb-0">
                        Alterando dados de
                        <strong><%= atendimento.nomeCliente %></strong>
                    </p>

                </div>

                <a href="/atendimento/list" class="btn btn-outline-dark">
                    Voltar
                </a>

            </div>

            <form id="formEdicao">

                <input value="<%= atendimento.id %>" type="hidden" id="atendimentoId">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nome do Cliente</label>
                        <input class="form-control" value="<%= atendimento.nomeCliente %>" type="text" id="nomeCliente">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Telefone</label>
                        <input class="form-control" value="<%= atendimento.telefone %>" type="text" id="telefone">
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Data Atendimento</label>
                        <input class="form-control" value="<%= atendimento.dataAtendimento %>" type="date" id="dataAtendimento">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Horário</label>
                        <input class="form-control" value="<%= atendimento.horarioAtendimento %>" type="time" id="horarioAtendimento">
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Nascimento</label>
                        <input class="form-control" value="<%= atendimento.dataNascimento %>" type="date" id="dataNascimento">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tipo de Serviço</label>
                        <input class="form-control" value="<%= atendimento.tipoServico %>" type="text" id="tipoServico">
                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label">Profissional</label>

                    <select class="form-control" name="profissional" id="profissional">

                        <% for(const usuario of usuarios) { %>

                            <option value="<%= usuario.id %>"
                                <%= String(atendimento.profissional) === String(usuario.id) ? "selected" : "" %>>
                                <%= usuario.nome %>
                            </option>

                        <% } %>

                    </select>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a href="/atendimento/list" class="btn btn-secondary">
                        Cancelar
                    </a>

                    <button class="btn btn-primary" type="submit" id="btnSalvar">
                        Atualizar Atendimento
                    </button>

                </div>

            </form>

        </div>

    </div>

</body>

</html>
