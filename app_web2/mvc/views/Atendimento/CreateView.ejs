<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Criar Atendimento</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Rubik", sans-serif;
            background-color: #F9DC5C;
            color: #f3f4f4;
        }

        #card {
            background-color: #F7F3E3;
            width: 500px; /* Aumentado levemente para comportar mais campos */
        }

        h1 {
            color: #6F1A07;
            font-size: 1.8rem;
        }

        label {
            color: #2B2118;
            font-weight: 500;
        }
    </style>
</head>

<body>

    <div class="container py-5 d-flex justify-content-center align-items-center">

        <div class="card p-4 shadow" id="card">

            <div class="mb-3" id="mensagem"></div>

            <form id="formAtendimento">
                <h1 class="text-center mb-4">Novo Atendimento</h1>

                <div class="mb-3">
                    <label class="form-label" for="nomeCliente">Nome do Cliente</label>
                    <input class="form-control" id="nomeCliente" type="text" required>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="telefone">Telefone</label>
                        <input class="form-control" id="telefone" type="tel" placeholder="(00) 00000-0000">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="dataNascimento">Data de Nascimento</label>
                        <input class="form-control" id="dataNascimento" type="date">
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="dataAtendimento">Data do Atendimento</label>
                        <input class="form-control" id="dataAtendimento" type="date" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="horarioAtendimento">Horário</label>
                        <input class="form-control" id="horarioAtendimento" type="time" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" for="tipoServico">Tipo de Serviço</label>
                    <input class="form-control" id="tipoServico" type="text" placeholder="Ex: Manicure, Consulta, etc.">
                </div>

                <div class="mb-4">
                    <label class="form-label" for="profissional">Profissional</label>

                    <select required name="profissional" id="profissional">
                        <% for(usuario of usuarios){ %>
                            <option value="<%= usuario.id %> "><%= usuario.nome %></option>
                        <% } %>
                    </select>
                </div>

                <div class="mb-2">
                    <button class="btn btn-primary w-100" id="btnCadastrar" type="submit" style="background-color: #6F1A07; border: none;">
                        Agendar Atendimento
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const form = document.getElementById("formAtendimento");
        const mensagem = document.getElementById("mensagem");

        form.addEventListener("submit", cadastrarAtendimento);

        async function cadastrarAtendimento(e) {
            e.preventDefault();

            // Captura dos valores
            const payload = {
                nomeCliente: document.getElementById("nomeCliente").value,
                telefone: document.getElementById("telefone").value,
                dataNascimento: document.getElementById("dataNascimento").value,
                dataAtendimento: document.getElementById("dataAtendimento").value,
                horarioAtendimento: document.getElementById("horarioAtendimento").value,
                tipoServico: document.getElementById("tipoServico").value,
                profissional: document.getElementById("profissional").value
            };

            const url = "/atendimento/create";

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    mensagem.innerHTML = `
                        <div class="alert alert-success">
                            Atendimento agendado com sucesso!
                        </div>
                    `;
                    form.reset(); // Limpa todos os campos
                } else {
                    throw new Error();
                }
            } catch (error) {
                mensagem.innerHTML = `
                    <div class="alert alert-danger">
                        Erro ao cadastrar atendimento! Verifique os dados.
                    </div>
                `;
            }
        }
    </script>

</body>
</html>