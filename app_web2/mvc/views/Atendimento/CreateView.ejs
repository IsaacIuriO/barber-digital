<!DOCTYPE html>
<html lang="pt-br">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SGP - Criar Atendimento</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            font-family: "Rubik", sans-serif;
            background-color: #F9DC5C;
        }

        .main-card{
            background-color: #F7F3E3;
            border: none;
            border-radius: 12px;
        }

        h1{
            color: #6F1A07;
            font-weight: 700;
        }

        label{
            color: #2B2118;
            font-weight: 500;
        }

        .btn-primary{
            background-color: #6F1A07;
            border: none;
        }

        .btn-primary:hover{
            background-color: #541404;
        }

    </style>

</head>

<body>

    <div class="container py-5">

        <div class="card main-card p-4 shadow">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                    <h1>Novo Atendimento</h1>
                    <p class="text-muted mb-0">
                        Cadastre um novo atendimento.
                    </p>
                </div>

                <a href="/atendimento/list" class="btn btn-outline-dark">
                    Voltar
                </a>

            </div>

            <form id="formAtendimento">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="nomeCliente">Nome do Cliente</label>
                        <input class="form-control" type="text" id="nomeCliente" placeholder="Ex: Maria Oliveira" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="telefone">Telefone / WhatsApp</label>
                        <input class="form-control" type="tel" id="telefone" placeholder="(11) 99999-9999" required>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="dataAtendimento">Data do Atendimento</label>
                        <input class="form-control" type="date" id="dataAtendimento" required>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="horarioAtendimento">Horário</label>
                        <input class="form-control" type="time" id="horarioAtendimento" required>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label" for="dataNascimento">Data de Nascimento</label>
                        <input class="form-control" type="date" id="dataNascimento" required>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="tipoServico">Tipo de Serviço</label>
                        <input class="form-control" type="text" id="tipoServico" placeholder="Ex: Consultoria Técnica" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label" for="profissional">Profissional Responsável</label>

                        <select class="form-control" name="profissional" id="profissional">

                            <% for(const usuario of usuarios){ %>

                                <option value="<%= usuario.id %>">
                                    <%= usuario.nome %>
                                </option>

                            <% } %>

                        </select>

                    </div>

                </div>

                <div class="d-flex justify-content-end mt-4">

                    <button class="btn btn-primary" type="submit" id="btnSubmit">
                        Cadastrar Atendimento
                    </button>

                </div>

            </form>

        </div>

    </div>

    <script>

        const form = document.getElementById("formAtendimento");

        form.addEventListener("submit", async (e) => {

            e.preventDefault();

            const btn = document.getElementById("btnSubmit");

            btn.innerText = "Agendando...";
            btn.disabled = true;

            const payload = {
                nomeCliente: document.getElementById("nomeCliente").value,
                telefone: document.getElementById("telefone").value,
                horarioAtendimento: document.getElementById("horarioAtendimento").value,
                dataAtendimento: document.getElementById("dataAtendimento").value,
                dataNascimento: document.getElementById("dataNascimento").value,
                tipoServico: document.getElementById("tipoServico").value,
                profissional: document.getElementById("profissional").value
            };

            try {

                const response = await fetch("/atendimento/create", {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if(response.ok){
                    alert("Atendimento cadastrado com sucesso!");
                    form.reset();
                }
                else{
                    alert("Erro ao cadastrar atendimento.");
                }

            }
            catch(err){
                alert("Erro de conexão.");
            }
            finally{
                btn.innerText = "Cadastrar Atendimento";
                btn.disabled = false;
            }

        });

    </script>

</body>

</html>
