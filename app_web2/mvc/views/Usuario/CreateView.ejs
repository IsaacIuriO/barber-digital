<!DOCTYPE html>

<html lang="pt-br">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Create</title>

        <!-- Bootstrap -->
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css">

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&display=swap" rel="stylesheet">

        <style>
            *{
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body{
                font-family: "Rubik", sans-serif;
                background-color: #F9DC5C;
                color: #f3f4f4;
            }

            #card{
                background-color: #F7F3E3;
                width: 400px;
            }

            h1{
                color: #6F1A07
            }

            label{
                color: #2B2118;
            }
            </style>

    </head>

    <body>
        <div class="container vh-100 d-flex justify-content-center align-items-center">
        
            <div class="card p-4" id="card">
            
                <div class="mb-3" id="mensagem"></div>

                <form>

                    <h1 class="text-center mb-4">Cadastro de Usuário</h1>

                    <div class="mb-3">
                        <label class="form-label" for="username">Username</label>
                        <input class="form-control" id="username" type="username"></input>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="email">E-mail</label>
                        <input class="form-control" id="email" type="email"></input>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="senha">Senha</label>
                        <input class="form-control" id="senha" type="password" name="senha"></input>
                    </div>

                    <div class="mb-3">
                        <button class="btn btn-primary w-100" id="btnCadastrarUsuario" type="submit">Cadastrar</button>
                    </div>


                </form>

            </div>

        </div>

        <script>
            const btnCadastrarUsuario = document.getElementById("btnCadastrarUsuario")

            btnCadastrarUsuario.addEventListener("click", cadastrarUsuario)

            async function cadastrarUsuario(e)
            {
                e.preventDefault()

                const username = document.getElementById("username")
                const email = document.getElementById("email")
                const senha = document.getElementById("senha")
                const mensagem = document.getElementById("mensagem")

                const url = "/user/create"

                const response = await fetch(url,
                {
                    method:'POST',
                    headers:{ 'Content-Type':'application/json' },
                    body: JSON.stringify(
                    {
                        username: username.value,
                        email: email.value,
                        senha: senha.value
                    })
                })

                const data = await response.text()

                if(response.ok)
                {
                    mensagem.innerHTML = `
                        <div class="alert alert-success">
                            Usuário cadastrado com sucesso!
                        </div>
                    `

                    username.value = ""
                    email.value = ""
                    senha.value = ""
                }
                else
                {
                    mensagem.innerHTML = `
                        <div class="alert alert-danger">
                            Erro ao cadastrar usuário!
                        </div>
                    `
                }

                console.log(data)
            }
        </script>
    </body>
</html>